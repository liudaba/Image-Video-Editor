# ===== 数据库配置 =====
# 注意：DATABASE_URL 中嵌入的密码必须与 DB_PASSWORD 一致
DATABASE_URL=postgresql+asyncpg://videogen:your_secure_password@db:5432/videogen
DB_PASSWORD=your_secure_password

# ===== Redis配置 =====
# 注意：REDIS_URL 中嵌入的密码必须与 REDIS_PASSWORD 一致
REDIS_URL=redis://:your_secure_redis_password@redis:6379/0
REDIS_PASSWORD=your_secure_redis_password

# ===== JWT配置 =====
# 必须配置！运行 python -c "import secrets; print(secrets.token_hex(32))" 生成
JWT_SECRET_KEY=change-this-to-a-very-long-random-string-at-least-64-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# ===== HMAC签名密钥 =====
# 必须配置！必须与客户端的 .license_verify_key 文件内容一致
# 运行 python -c "import secrets; print(secrets.token_hex(32))" 生成
HMAC_SIGN_KEY=change-this-after-running-init-db

# ===== 授权配置 =====
TRIAL_DAYS=7
GRACE_HOURS=2

# ===== 站点基础URL =====
# 用于生成支付回调地址等
SITE_BASE_URL=https://api.videogen.com

# ===== 支付宝配置（内测阶段留空）=====
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY_PATH=keys/alipay_private_key.pem
ALIPAY_PUBLIC_KEY_PATH=keys/alipay_public_key.pem
ALIPAY_NOTIFY_URL=

# ===== 微信支付配置（内测阶段留空）=====
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_CERT_PATH=keys/wechat_cert.pem
WECHAT_KEY_PATH=keys/wechat_key.pem
WECHAT_NOTIFY_URL=

# ===== SMTP邮件配置（密码重置功能需要）=====
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ===== 管理员配置 =====
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ===== CORS配置 =====
# 备案通过后改为你的域名
CORS_ORIGINS=["https://api.videogen.com","http://localhost"]

# ===== 限流配置 =====
RATE_LIMIT_PER_MINUTE=60

# ===== 环境标识 =====
VIDEOGEN_ENV=production

# ===== 日志级别 =====
LOG_LEVEL=INFO
