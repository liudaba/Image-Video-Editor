# 短视频生成器 - 后端服务环境变量配置
# 部署时请复制此文件为 .env 并填入真实值

# ===== 必填项 =====

# JWT签名密钥（首次启动自动生成，生产环境必须固定）
VIDEOGEN_SECRET_KEY=

# 授权签名密钥（首次启动自动生成，生产环境必须固定）
# 此密钥同时用于服务端签名和客户端验证
VIDEOGEN_LICENSE_SIGN_KEY=

# 管理员Token（首次启动自动生成，用于版本发布和管理接口）
VIDEOGEN_ADMIN_TOKEN=

# ===== 虎皮椒支付配置 =====

# 虎皮椒商户ID
VIDEOGEN_HUPPIAO_PID=

# 虎皮椒商户密钥
VIDEOGEN_HUPPIAO_SECRET=

# 支付回调地址（必须是外网可访问的HTTPS地址）
VIDEOGEN_PAY_NOTIFY_URL=https://api.videogen.com/api/payment/notify

# 虎皮椒API地址
VIDEOGEN_HUPPIAO_API=https://api.xunhupay.com/payment/do.html

# ===== 可选项 =====

# 数据库路径（默认: backend/videogen.db）
VIDEOGEN_DB_PATH=

# 服务端口（默认: 8000）
VIDEOGEN_PORT=8000

# Gunicorn Worker数量（默认: 4）
VIDEOGEN_WORKERS=4
