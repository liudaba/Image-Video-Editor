DATABASE_URL=postgresql+asyncpg://videogen:your_secure_password@db:5432/videogen
REDIS_URL=redis://:changeme@redis:6379/0
JWT_SECRET_KEY=change-this-to-a-very-long-random-string-at-least-64-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
HMAC_SIGN_KEY=change-this-to-match-client-license-verify-key
TRIAL_DAYS=7
GRACE_HOURS=2
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY_PATH=keys/alipay_private_key.pem
ALIPAY_PUBLIC_KEY_PATH=keys/alipay_public_key.pem
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_CERT_PATH=keys/wechat_cert.pem
WECHAT_KEY_PATH=keys/wechat_key.pem
WECHAT_NOTIFY_URL=https://api.videogen.com/api/payment/wechat_notify
ALIPAY_NOTIFY_URL=https://api.videogen.com/api/payment/alipay_notify
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-immediately
CORS_ORIGINS=["https://videogen.com","https://www.videogen.com"]
RATE_LIMIT_PER_MINUTE=60
VIDEOGEN_ENV=production
DB_PASSWORD=your_secure_db_password
REDIS_PASSWORD=your_secure_redis_password
